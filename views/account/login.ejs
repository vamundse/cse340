<% if(title) { %>
<h1><%= title %></h1>
<% } else {
    res.redirect('/')
} %>

<% if(messages) { %>
<%- messages() %>
<% } else {
    res.redirect('/')
} %>

<form id="login-form">
    <label>Email:<input type="email" id="account_email" name="account_email" required></label>
    <label>Password:<input type="password" id="account_password" name="account_password" pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$" required></label>
    <div id="password-req">Passwords must be at least 12 characters and contain at least 1 number, 1 capital letter and 1 special character.</div>
    <button>Login</button>
    <p>No Account? <a href="/account/register">Sign-up</a></p>
</form>