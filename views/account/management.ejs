<% if(title) { %>
<h1><%= title %></h1>
<% } else {
    res.redirect('/')
} %>

<% if(messages) { %>
<%- messages() %>
<% } else {
    res.redirect('/')
} %>

<% if (errors) { %>
  <ul class="notice">
 <% errors.array().forEach(error => { %>
   <li><%= error.msg %></li>
<%  }) %>
 </ul>
<% } %>

<h2>Welcome <%- account_firstname %></h2>

<div id="account-view">
    <p>Your're logged in</p>
    <p><a href="/account/update/<%- account_id %>">Update you account details</a></p>

    <% if(account_type === "Admin" || account_type == "Employee") { %>
        <h3>Inventory Management</h3>
        <p><a href="/inv/">Go to inventory management</a></p>
    <% } %>
</div>
