<% if(title) { %>
<h1><%= title %></h1>
<% } else {
    res.redirect('/')
} %>

<% if(messages) { %>
<%- messages() %>
<% } else {
    res.redirect('/')
} %>

<% if (errors) { %>
  <ul class="notice">
 <% errors.array().forEach(error => { %>
   <li><%= error.msg %></li>
<%  }) %>
 </ul>
<% } %>

<form action="/account/register" method="post" id="register-form">
    <label>First name<input type="text" id="account_firstname" name="account_firstname" required></label>
    <label>Last name<input type="text" id="account_lastname" name="account_lastname" required></label>
    <label>Email address<input type="email" id="account_email" name="account_email" required></label>
    <label>Password
        <input type="password" id="account_password" name="account_password" pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$" required>
        <div id="password-req">Passwords must be at least 12 characters and contain at least 1 number, 1 capital letter and 1 special character.</div>
    </label>
    <button>Register</button>
</form>