<h1>Welcome to CSE Motors!</h1>
<%- messages() %>
<div id="hero">
    <img src="../images/vehicles/delorean.jpg" alt="Delorean Vehicle">
    <div id="hero-overlay">
        <h2>DMC Delorean</h2>
        <p>3 Cup holders</p>
        <p>Superman doors</p>
        <p>Fuzzy dicel</p>
        <a href="" class="button">Own Today</a>
    </div>
</div>
<div class="content-wrapper">
    <div id="reviews">
        <h1>DMC Delorean Reviews</h1>
        <ul>
            <li>"So fast it's almost like traveling in time." (4/5)</li>
            <li>"Coolest ride on the road." (4/5)</li>
            <li>"I'mfeeling McFly!" (5/5)</li>
            <li>"The most futuristic ride of our day." (4.5/5)</li>
            <li>"80's livin and I love it" (5/5)</li>
        </ul>
    </div>
    <div id="upgrade-section">
        <h1>Delorean Upgrades</h1>
        <div id="upgrades">
            <div class="upgrade">
                <picture>
                    <img src="../images/upgrades/flux-cap.png" alt="Flux capacitor">
                </picture>
                <a href="">Flux Capacitor</a>
            </div>
            <div class="upgrade">
                <picture>
                    <img src="../images/upgrades/flame.jpg" alt="Flame decals">
                </picture>
                <a href="">Flame Decals</a>
            </div>
            <div class="upgrade">
                <picture>
                    <img src="../images/upgrades/bumper_sticker.jpg" alt="Bumper stickers">
                </picture>
                <a href="">Bumper Stickers</a>
            </div>
            <div class="upgrade">
                <picture>
                    <img src="../images/upgrades/hub-cap.jpg" alt="Hub caps">
                </picture>
                <a href="">Hub Caps</a>
            </div>
        </div>
    </div>
</div>