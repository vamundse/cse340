<% if(title) { %>
<h1><%= title %></h1>
<% } else {
    res.redirect('/')
} %>

<% if(messages) { %>
<%- messages() %>
<% } else {
    res.redirect('/')
} %>

<% if (errors) { %>
  <ul class="notice">
 <% errors.array().forEach(error => { %>
   <li><%= error.msg %></li>
<%  }) %>
 </ul>
<% } %>

<form action="/inv/delete" method="post" id="delete-confirm">
    <label>Make:<input type="text" readonly id="inv_make" name="inv_make" required pattern="[a-zA-Z ]{2,}" value="<%= locals.inv_make %>"></label>
    <label>Model:<input type="text" readonly id="inv_model" name="inv_model" required pattern="[a-zA-Z ]{3,}" value="<%= locals.inv_model %>"></label>
    <label>Year:<input type="number" readonly id="inv_year" name="inv_year" required pattern="[0-9]{4}" value="<%= locals.inv_year %>"></label>
    <label>Price:<input type="number" readonly id="inv_price" name="inv_price" required minlength="1" value="<%= locals.inv_price %>"></label>
    <p>Confirm deletion - the delete is permanent.</p>
    <button type="submit">Delete Vehicle</button>
    <input type="hidden" name="inv_id"
    <% if(locals.inv_id) { %> value="<%= locals.inv_id %>"
    <% } %>>
</form>
